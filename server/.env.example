# ============================================================
# Medcare — Server Environment Variables (v3.2)
# NEVER commit .env to version control — Add to .gitignore
# ============================================================

# -- Firebase Admin SDK (REQUIRED for production) -------
# How to get: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Copy the ENTIRE JSON as a single-line string (no line breaks outside the \n in private key)
# Example format: {"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative for local development:
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# -- Server Configuration -------
PORT=5000
NODE_ENV=development

# -- CORS Configuration -------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# -- Logging -------
LOG_LEVEL=info

