# ============================================================
# Medcare Backend - .gitignore
# Prevents accidental commit of sensitive files
# ============================================================

# Environment variables (contains Firebase credentials)
.env
.env.local
.env.*.local

# Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log

# Cache
.cache/
.eslintcache

# OS
Thumbs.db
.DS_Store

# Firebase
firebase-debug.log
.firebase/
.firebaserc

# Testing
.nyc_output/
coverage/

# Temporary
tmp/
temp/
