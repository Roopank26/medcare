# ============================================================
# Medcare — ML Service Environment Variables (v4.1)
# NEVER commit .env to version control
# ============================================================

# Flask settings
FLASK_ENV=production
ML_PORT=5001

# CORS whitelist - CRITICAL for production
# Default includes localhost (dev) + production Vercel URLs
# Add your Vercel frontend URL here (comma-separated, no spaces)
ALLOWED_ORIGINS=https://medcare-theta-nine.vercel.app,https://medcare.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Low-confidence threshold (default 40%)
LOW_CONFIDENCE_THRESHOLD=40

# Optional: OpenAI API key (leave empty for rule-based chatbot)
OPENAI_API_KEY=
