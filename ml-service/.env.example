# ============================================================
# Medcare — ML Service Environment Variables (v4.1)
# NEVER commit .env to version control
# ============================================================

ML_PORT=5001
FLASK_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI API key (optional — falls back to rule-based chatbot)
OPENAI_API_KEY=

# Phase 2: Low-confidence threshold (default 40%)
LOW_CONFIDENCE_THRESHOLD=40
